# expect(...).to.be-less-than-or-equal-to(...) integration.
{
  Failures.list = ();
  ok expect(5).to.be-less-than-or-equal-to(5), 'passes on equal';
  ok expect(3).to.be-less-than-or-equal-to(5), 'passes on less';
