#!/usr/bin/env raku

use v6.d;
use lib 'lib';
use BDD::Behave::Runner;
use BDD::Behave::SpecRegistry;
use BDD::Behave::Files;

my $verbose = False;
my @specs = [];
my @include-tags;
my @exclude-tags;

sub usage() {
  say qq:to/HERE/;
  Usage: behave [options...] [specs/spec_file.raku]
    Runs the new tree-based runner against specs in the local `specs` directory
    or against a list of spec files provided on the command line.

  Options:
    --help                   Displays how to run behave.
    --verbose                Display verbose output during the specs execution.
    --tag NAME               Run only examples tagged NAME (repeatable; OR semantics).
    --exclude-tag NAME       Skip examples tagged NAME (repeatable).

  Tags inherit from enclosing describe/context blocks. --exclude-tag wins over
  --tag when both match the same example.
  HERE
}

sub split-eq(Str $arg) {
  my $eq = $arg.index('=');
  $eq.defined ?? ($arg.substr(0, $eq), $arg.substr($eq + 1)) !! ($arg, Str);
}

my @args = @*ARGS;
while @args {
  my $arg = @args.shift;

  if $arg eq '--help' {
    usage;
    exit;
  } elsif $arg eq '--verbose' {
    $verbose = True;
  } elsif $arg eq '--tag' {
    die "--tag requires a value" unless @args;
    @include-tags.push: @args.shift;
  } elsif $arg.starts-with('--tag=') {
    @include-tags.push: $arg.substr('--tag='.chars);
  } elsif $arg eq '--exclude-tag' {
    die "--exclude-tag requires a value" unless @args;
    @exclude-tags.push: @args.shift;
  } elsif $arg.starts-with('--exclude-tag=') {
    @exclude-tags.push: $arg.substr('--exclude-tag='.chars);
  } else {
    @specs.push: $arg;
  }
}

# Get list of spec files
my $files-obj = Files.new;
my @files = $files-obj.list(@specs);

# Load and eval spec files
use MONKEY-SEE-NO-EVAL;
use BDD::Behave::Colors;

my $registry = BDD::Behave::SpecRegistry::registry();
my $total-result = BDD::Behave::Runner::RunResult.new;
my $multi = @files.elems > 1;
my $suites-run = 0;

for @files -> $file {
  say "\nLoading: $file" if $verbose;
  try {
    EVALFILE $file;
    CATCH {
      default {
        note "Warning: Could not load $file: {.message}";
        note "  (This spec may use legacy syntax incompatible with the new runner)";
      }
    }
  }

  my $suite = $registry.suite-for-file($file.IO);
  next unless $suite.defined;

  say "\n" ~ light-blue($suite.file.basename) if $multi;

  my $runner = BDD::Behave::Runner::Runner.new(
    :include-tags(@include-tags),
    :exclude-tags(@exclude-tags),
  );
  my $result = $runner.run($suite);
  $suites-run++;

  $total-result = BDD::Behave::Runner::RunResult.new(
    :total($total-result.total + $result.total),
    :passed($total-result.passed + $result.passed),
    :failed($total-result.failed + $result.failed),
    :pending($total-result.pending + $result.pending),
    :skipped($total-result.skipped + $result.skipped),
  );
}

if $suites-run > 1 {
  say "\n" ~ "=" x 60;
  say "Overall: {$total-result.total} example" ~ ($total-result.total == 1 ?? '' !! 's');
  say red("  {$total-result.failed} failed")           if $total-result.failed > 0;
  say light-blue("  {$total-result.pending} pending")  if $total-result.pending > 0;
  say light-blue("  {$total-result.skipped} skipped")  if $total-result.skipped > 0;
  say green("  {$total-result.passed} passed")         if $total-result.passed > 0;
}

# Exit with appropriate code
exit($total-result.success ?? 0 !! 1);
